{
  "files": ["./src/main.ts"],
  "compilerOptions": {
    "target": "es5",
    "outFile": "./build/index.js",
    "strict": true,
    "noUnusedLocals": true,
    "noImplicitReturns": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "types": ["nakama-runtime"]
  }
}
