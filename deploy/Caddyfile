193-238-134-75.sslip.io {
	encode gzip
	header {
		Cross-Origin-Opener-Policy "same-origin"
		Cross-Origin-Embedder-Policy "require-corp"
	}

	# Сохраняем старый /godot/* — редирект на корень, чтобы старые ссылки не ломались.
	redir /godot{uri} / 301
	redir /godot/{uri} / 301

	root * /srv-godot
	try_files {path} /index.html
	file_server
}

